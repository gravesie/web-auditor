# Copy to .env and adjust for your machine. .env is gitignored.
APP_ENV=development

# Postgres connection. Matches docker-compose.yml.
DATABASE_URL=postgresql+psycopg://webauditor:webauditor@localhost:5432/webauditor

# Used later to encrypt stored connector credentials. Change for any non-local use.
SECRET_KEY=change-me-in-production

# Google PageSpeed Insights API key (performance audit). Optional; PSI works
# keyless at a lower quota. Get one in the Google Cloud console.
PAGESPEED_API_KEY=

# Resend API key for emailing the PDF report. Without it, the report is written
# to the outbox as a .eml file instead of being sent.
RESEND_API_KEY=

# Anthropic API key for the LLM judgement passes. Optional; those checks degrade
# to needs-connection without it.
ANTHROPIC_API_KEY=

# Google OAuth client for the Search Console + GA4 connectors. Create an OAuth 2.0
# client (type "Web application") in the Google Cloud console. Add the redirect URI
# below to it, enable the Search Console, Analytics Data and Analytics Admin APIs,
# and add yourself as a test user. Without these the connect flow is disabled.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/connections/google/callback
